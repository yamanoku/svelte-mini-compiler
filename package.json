{
  "name": "svelte-mini-compiler",
  "private": true,
  "description": "sveltejs/svelte の compiler() の仕組み（parse → analyze → transform）を参考にした、HTML解析のみのコンパイラ",
  "type": "module",
  "scripts": {
    "demo": "node lib/demo.ts",
    "build:app": "node lib/build.ts",
    "serve": "node lib/build.ts && node lib/serve.ts",
    "test": "node --test 'src/**/*.test.ts'",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=26"
  }
}
