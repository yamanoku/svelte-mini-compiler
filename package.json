{
	"name": "svelte-mini-compiler",
	"private": true,
	"type": "module",
	"description": "sveltejs/svelte の compiler() の仕組み（parse → analyze → transform）を参考にした、HTML解析のみのコンパイラ",
	"scripts": {
		"demo": "node src/main.ts",
		"test": "node --test 'src/**/*.test.ts'",
		"build": "tsc",
		"check": "tsc --noEmit"
	},
	"engines": {
		"node": ">=26"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"typescript": "^7.0.2"
	}
}
